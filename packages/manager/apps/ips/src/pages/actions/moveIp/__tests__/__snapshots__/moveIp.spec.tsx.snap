exports[`Move IP modal > lets you go to step 2 if you fill correctly destination service and next hop 1`] = `"<div class="flex items-center mb-4"><ods-text preset="heading-4" class="block mr-3 flex-1 ods-text">move Additional IP</ods-text><ods-text preset="caption" class="ml-auto ods-text">stepPlaceholder</ods-text></div><div class="flex  flex-col text-left"><div class="flex items-center"><ods-text preset="paragraph" class="block mb-4 text-center flex-1"><span class="text-sm">Voulez vous vraiment déplacer l'IP <b>239.99.244.14/32</b> vers <b>01234506</b> ?</span></ods-text></div></div><ods-button data-testid="secondary-button" slot="actions" color="primary" variant="ghost" label="previous" type="button" class="mt-4 ods-button ods-button--md" icon-alignment="left" size="md"></ods-button><ods-button data-testid="primary-button" slot="actions" color="primary" is-disabled="false" is-loading="false" variant="default" label="confirm" type="button" class="mt-4 ods-button ods-button--md" icon-alignment="left" size="md"></ods-button>"`;
