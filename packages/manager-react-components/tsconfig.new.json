{
  "compilerOptions": {
    "lib": ["dom", "es2021"],
    "target": "ES2020",
    "types": ["vite/client", "node", "jest"],
    "module": "ESNext",
    "outDir": "dist",
    "allowJs": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "jsx": "react-jsx",
    "strict": true
  },
  "files": ["global.d.ts"],
  "include": [
    // Add you components migrated here
  ],
  "exclude": [
    "./src/hooks/*",
    "./src/utils/*",
    "./src/tailwind/*",
    "./src/__mocks__/*",
    "./src/enumTypes/*"
  ]
}
