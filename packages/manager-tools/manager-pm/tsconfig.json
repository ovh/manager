{
  "extends": "@ovh-ux/manager-static-analysis-kit/tsconfig/node-strict",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "allowJs": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "types"]
}
